(ns basilisp.test
  "Basilisp automated testing framework.

  The functions and macros in this namespace are useful in defining automated tests
  for your Basilisp code. Basilisp's builtin test runner is a plugin for PyTest and
  benefits from many PyTest features such as test collection and subsetting.

  Test namespaces should generally be placed in a ``tests`` directory in the root of
  your project. Tests may be organized into single namespaces or nested namespaces.
  All test namespace files should be named ``test_*.lpy`` or ``*_test.lpy`` to be
  eligible for collection by the test runner.

  Tests within each test namespace should be wrapped in an outer :lpy:fn:`deftest`
  form and may optionally be organized within each form with :lpy:fn:`testing` forms.
  :lpy:fn:`is` and :lpy:fn:`are` may be used for making test assertions. All assertions
  will be processed in order to the end and all failures and errors will be reported
  at once.

  Tests may take advantage of Basilisp fixtures via :lpy:fn:`use-fixtures` to perform
  setup and teardown functions for each test or namespace. Fixtures are not the same
  (nor are they compatible with) PyTest fixtures."
  (:import
   inspect
   types
   [basilisp.lang.stm :as stm])
  (:require
   [basilisp.template :as template]))

(def ^:dynamic *test-name* nil)
(def ^:dynamic *test-section* nil)
(def ^:dynamic *test-failures* nil)
(def ^:dynamic *test-passes* nil)
(def ^:dynamic *load-tests* true)
(def ^:dynamic *test-line* nil)
(def ^:dynamic *testing-vars* [])
(def ^:dynamic *testing-contexts* '())
(def ^:dynamic *test-results* nil)
(def ^:dynamic *test-output* true)
;; Clojure.test reporting bindings.  The existing structured runner remains the
;; source of its summaries; these Vars let ordinary Clojure.test extensions and
;; custom reporters use their documented counter/output hooks.
(def ^:dynamic *stack-trace-depth* nil)
(def ^:dynamic *initial-report-counters* {:test 0 :pass 0 :fail 0 :error 0})
(def ^:dynamic *report-counters* nil)
(def ^:dynamic *test-out* *out*)

(defmacro with-test-out
  "Run ``body`` with ``*out*`` bound to the current ``*test-out*`` writer."
  [& body]
  `(binding [*out* *test-out*]
     ~@body))

(defn inc-report-counter
  "Increment ``name`` in the active Clojure-style report counter, if any."
  [name]
  (when *report-counters*
    (if (instance? stm/Ref *report-counters*)
      (dosync (commute *report-counters* update name (fnil inc 0)))
      (swap! *report-counters* update name (fnil inc 0)))))

(defmulti ^:dynamic report
  "Report an assertion event. Applications may add methods to customize reporting.
  The default methods preserve Basilisp's structured test results."
  (fn [m] (:type m)))

(defn record-report!
  "Record an assertion event in the active test result.

  Custom report renderers should call this before producing output so that a
  test's structured result remains independent of its presentation."
  [m]
  (case (:type m)
    :pass    (when *test-passes* (vswap! *test-passes* inc))
    :fail    (when *test-failures* (vswap! *test-failures* conj (assoc m :type :failure)))
    :failure (when *test-failures* (vswap! *test-failures* conj m))
    :error   (when *test-failures* (vswap! *test-failures* conj m))
    nil))

(defmethod report :pass
  [m]
  (record-report! m)
  (inc-report-counter :pass))

(defmethod report :fail
  [m]
  (record-report! m)
  (inc-report-counter :fail))

(defmethod report :failure
  [m]
  (record-report! m)
  (inc-report-counter :fail))

(defmethod report :error
  [m]
  (record-report! m)
  (inc-report-counter :error))

(defmethod report :default
  [m]
  (println m))

;; Standard lifecycle events are hooks for alternate reporters; the default
;; Clojure.test behavior intentionally produces no output for them.
(defmethod report :begin-test-ns [_])
(defmethod report :end-test-ns [_])
(defmethod report :begin-test-var [_])
(defmethod report :end-test-var [_])

(defn do-report
  "Add the current test context to assertion event ``m`` and dispatch it through
  :lpy:fn:`report`. Custom assertion methods should call this function."
  [m]
  (report (merge {:test-name    *test-name*
                  :test-section *test-section*
                  :testing-contexts *testing-contexts*
                  :line         *test-line*}
                 m)))

(defmulti ^{:arglists '([fixture-type & fixtures])}
  use-fixtures
  "Configure fixture functions to be run for each test or once per namespace.

  ``fixture-type`` may be one of:

  - ``:each`` to specify that a fixture should be run before each test
  - ``:once`` to specify that a fixture should be run once per test namespace

  Fixtures may use either of two forms. A zero-argument fixture may return a value
  or temporarily ``yield`` control back to the test runner after setup. A
  one-argument fixture receives a thunk which it calls to run the test or tests;
  setup runs before calling the thunk and teardown runs after it returns.

  For example, to define a fixture with setup and teardown functions, your fixture
  may take this form::

    (fn fixture []
      (setup-test)
      (yield)
      (teardown-test))

  Fixtures will be run in the order they are provided.

  Subsequent calls to ``use-fixtures`` in the same test namespace will overwrite
  fixtures applied during previous calls for the same ``fixture-type``.

  Note that due to the way fixtures are applied, the set of fixtures that are active
  for each ``fixture-type`` after all tests are collected will be applied to all tests.
  It is not possible to apply specific fixtures to individual tests by adding fixtures
  via ``use-fixture`` and then removing them after the test is defined."
  (fn [fixture-type & _] fixture-type))

(defn generator?
  "Return true if ``x`` is a generator type, else false."
  [x]
  (instance? types/GeneratorType x))

(defn fixture-takes-thunk?
  "Return true when ``fixture`` accepts a test thunk but not a zero-argument call."
  [fixture]
  (let [signature (inspect/signature fixture)]
    (try
      (.bind signature)
      false
      (catch python/TypeError _
        (try
          (.bind signature (fn [] nil))
          true
          (catch python/TypeError _
            (throw (python/TypeError
                    "Basilisp test fixtures must accept either zero arguments or one test thunk"))))))))

(defmethod use-fixtures :each
  [_ & fixtures]
  (alter-meta! *ns* assoc ::each-fixtures fixtures))

(defmethod use-fixtures :once
  [_ & fixtures]
  (alter-meta! *ns* assoc ::once-fixtures fixtures))

(defmacro with-fixtures
  "Wrap the ``body`` in the ``fixtures`` in the given order. Handle
  setup and teardown for each of the ``fixtures``."
  [fixtures & body]
  (assert (vector? fixtures) "Expected a literal vector of fixtures")
  (let [result (gensym "result")]
    (reduce (fn [form fixture]
              `(let [fixture# ~fixture]
                 (if (fixture-takes-thunk? fixture#)
                   (fixture# (fn [] ~form))
                   (let [~result (fixture#)]
                     (if (generator? ~result)
                       (try
                         (python/next ~result)
                         ~form
                         (finally
                           (try
                             (python/next ~result)
                             (catch python/StopIteration ~'_ nil))))
                       ~form)))))
            `(do ~@body)
            (reverse fixtures))))

(defmacro compose-fixtures
  "Compose any number of ``fixtures``, in order, creating a new fixture
  that combines their behavior. Always returns a valid fixture
  function, even if no fixtures are given."
  [& fixtures]
  `(fn [] (with-fixtures [~@fixtures] (yield))))

(defn join-fixtures
  "Composes a collection of ``fixtures``, in order.  Always returns a valid
  fixture function, even if the collection is empty.
  Prefer :lpy:fn:`compose-fixtures` if fixtures are known at compile time."
  [fixtures]
  (if (seq fixtures)
    (reduce #(compose-fixtures %1 %2) fixtures)
    (constantly nil)))

(defn file-position
  "Return ``[filename line-number]`` for the caller ``n`` frames above this one.

  This deprecated Clojure.test helper uses Python frame information rather than
  JVM stack-trace elements, but retains its useful source-location shape.
  "
  [n]
  (loop [frame (inspect/currentframe)
         remaining (+ n 1)]
    (if (or (nil? frame) (zero? remaining))
      (if frame
        [(.-co_filename (.-f_code frame)) (.-f_lineno frame)]
        [nil nil])
      (recur (.-f_back frame) (dec remaining)))))

(defn get-possibly-unbound-var
  "Like ``var-get`` but return ``nil`` when a Basilisp Var is unbound."
  [v]
  (when (.-is-bound v)
    (var-get v)))

(defn function?
  "Return true for a function or a symbol resolving to a non-macro function."
  [value]
  (if (symbol? value)
    (when-let [v (resolve value)]
      (when-let [f (get-possibly-unbound-var v)]
        (and (fn? f) (not (:macro (meta v))))))
    (fn? value)))

(defn assert-predicate
  "Generate Clojure.test-style assertion code for a predicate call form."
  [msg form]
  (let [args (rest form)
        pred (first form)]
    `(let [values# (list ~@args)
           result# (apply ~pred values#)]
       (if result#
         (do-report {:type :pass :message ~msg
                     :expected (quote ~form) :actual (cons (quote ~pred) values#)})
         (do-report {:type :fail :message ~msg
                     :expected (quote ~form)
                     :actual (list (quote not) (cons (quote ~pred) values#))}))
       result#)))

(defn assert-any
  "Generate Clojure.test-style assertion code for an arbitrary form."
  [msg form]
  `(let [value# ~form]
     (if value#
       (do-report {:type :pass :message ~msg
                   :expected (quote ~form) :actual value#})
       (do-report {:type :fail :message ~msg
                   :expected (quote ~form) :actual value#}))
     value#))

(defmulti
  ^{:arglists '([msg expr])}
  assert-expr
  "Generate assertion code for :lpy:fn:`is`. Extend this multimethod to add
  custom assertion forms. Methods receive the optional assertion message followed
  by the unevaluated assertion form and should return code that calls
  :lpy:fn:`do-report`."
  (fn [_ expr]
    (cond
      (vector? expr)     :default
      (sequential? expr) (let [maybe-f (first expr)]
                           (if (symbol? maybe-f)
                             (cond
                               (= 'basilisp.core/= maybe-f) (symbol (name maybe-f))
                               (#{'thrown-with-msg? 'thrown?} (symbol maybe-f))
                               (symbol (name maybe-f))
                               ;; clojure-test-suite defines this portable assertion
                               ;; method with Basilisp's pre-0.5 argument order.
                               ;; Dispatch it to our compatible implementation instead
                               ;; of evaluating ``p/thrown?`` as a regular function.
                               (= 'p/thrown? maybe-f) 'portable-thrown?
                               :else maybe-f)
                             maybe-f))
      :else              :default)))

(defmethod assert-expr '=
  [msg expr]
  `(let [expected# ~(second expr)
         actual#   ~(nth expr 2)]
     (if (= expected# actual#)
       (do-report {:type :pass
                   :message ~msg
                   :expr (quote ~expr)
                   :actual (list (symbol "=") expected# actual#)
                   :expected (quote ~expr)})
       (do-report {:type :fail
                   :message ~msg
                   :expr (quote ~expr)
                   :actual (list (symbol "=") expected# actual#)
                   :expected (quote ~expr)}))))

(defmethod assert-expr 'thrown?
  [msg expr]
  (let [exc-type (second expr)
        body     (nthnext expr 2)]
    `(try
       (let [result# (do ~@body)]
         (do-report {:type :fail
                     :message ~msg
                     :expr (quote ~expr)
                     :actual result#
                     :expected (quote ~exc-type)}))
       (catch ~exc-type e#
         (do-report {:type :pass
                     :message ~msg
                     :expr (quote ~expr)
                     :actual e#
                     :expected (quote ~exc-type)})
         e#)
       (catch python/Exception e#
         (do-report {:type :fail
                     :message (str "Expected " ~exc-type "; got " (python/type e#) " instead")
                     :expr (quote ~expr)
                     :actual e#
                     :expected ~exc-type})))))

(defmethod assert-expr 'thrown-with-msg?
  [msg expr]
  (let [exc-type (second expr)
        pattern  (nth expr 2)
        body     (nthnext expr 3)]
    `(try
       (let [result# (do ~@body)]
         (do-report {:type :fail
                     :message ~msg
                     :expr (quote ~expr)
                     :actual result#
                     :expected (quote ~exc-type)}))
       (catch ~exc-type e#
         ;; Use python/str rather than Basilisp str to get the raw "message"
         ;; from the exception.
         (let [string-exc# (python/str e#)]
           (if (re-find ~pattern string-exc#)
             (do-report {:type :pass
                         :message ~msg
                         :expr (quote ~expr)
                         :actual e#
                         :expected ~pattern})
             (do-report {:type :fail
                         :message "Regex pattern did not match"
                         :expr (quote ~expr)
                         :actual string-exc#
                         :expected ~pattern}))))
       (catch python/Exception e#
         (do-report {:type :fail
                     :message (str "Expected " ~exc-type "; got " (python/type e#) " instead")
                     :expr (quote ~expr)
                     :actual e#
                     :expected ~exc-type})))))

(defmethod assert-expr 'portable-thrown?
  [msg expr]
  "Support clojure-test-suite's portable ``p/thrown?`` assertion form.

  Unlike :lpy:fn:`thrown?`, this form accepts no exception class and succeeds
  for any ordinary Python exception."
  (let [body (rest expr)]
    `(try
       (let [result# (do ~@body)]
         (do-report {:type :fail
                     :message ~msg
                     :expr (quote ~expr)
                     :actual result#
                     :expected (quote ~expr)}))
       (catch python/Exception e#
         e#))))

(defmethod assert-expr :default
  [msg expr]
  (if (and (sequential? expr) (function? (first expr)))
    (assert-predicate msg expr)
    (assert-any msg expr)))

(defmulti gen-assert
  "Legacy assertion generation extension point. New code should extend
  :lpy:fn:`assert-expr`; existing three-argument methods remain supported."
  (fn [expr _ _]
    (cond
      (vector? expr)     :default
      (sequential? expr) (first expr)
      :else              :default)))

(defmethod gen-assert :default
  [expr msg _]
  (assert-expr msg expr))

(defmacro try-expr
  "Evaluate a generated assertion and report an unexpected ordinary exception."
  [msg form]
  `(try
     ~(assert-expr msg form)
     (catch python/Exception e#
       (do-report {:type :error :message ~msg
                   :expected (quote ~form) :actual e#}))))

(defmacro is
  "Assert that a test condition, ``expr``, is true. :lpy:fn:`is` assertion failures are
  recorded and reported as test failures, causing the entire containing ``deftest`` to
  be marked as failed.

  ``expr`` can take multiple forms:

  - ``(is (= expected actual))`` generates a basic assertion that ``expected`` and
    ``actual`` are equal by ``=``; error messaging will reflect that the first element
    is the expected value and the second element is the actual value
  - ``(is (thrown? ExceptionType expr))`` generates a basic assertion that ``expr``
    does generate an exception of the type ``ExceptionType``
  - ``(is (thrown-with-msg? ExceptionType pattern expr))`` generates a basic assertion
    that ``expr`` does generate an exception of the type ``ExceptionType`` and that
    the stringified exception (as by ``python/str``) matches the regular expression
    ``pattern`` using :lpy:fn:`re-find`
  - ``(is expr)`` is the most basic assertion type that just asserts that ``expr`` is
    truthy

  ``is`` assertions must appear inside of a :lpy:fn:`deftest` form."
  ([expr]
   `(is ~expr nil))
  ([expr msg]
   (let [line-num (or (:basilisp.lang.reader/line (meta &form))
                      (:basilisp.lang.reader/line (meta (first &form))))
         exc-name (gensym "e")]
     `(binding [*test-line* ~line-num]
        (try
          ~(gen-assert expr msg line-num)
          (catch python/Exception ~exc-name
            (do-report {:type :error
                        :message ~msg
                        :expr (quote ~expr)
                        :actual ~exc-name
                        :expected (quote ~expr)
                        :line ~(if line-num
                                 line-num
                                 `(.-tb_lineno (.-__traceback__ ~exc-name)))})))))))

(defmacro are
  "Generate assertions using the template expression ``expr``. Template expressions
  should be defined in terms of the symbols in the argument vector ``argv``.

  Arguments will be partitioned into groups of as many arguments are in ``argv``
  and applied to the template expression.

  As an example::

    (are [res x y] (= res (+ x y))
      3  1 2
      4  2 2
      0 -1 1)

  This would macroexpand to create a group of assertions like this::

    (do
      (is (= 3 (+ 1 2)))
      (is (= 4 (+ 2 2)))
      (is (= 0 (+ -1 1))))

  This may be convenient for generating large numbers of identically formed assertions
  with different arguments. Assertion failures report the line of the ``are`` form.

  ``are`` assertions must appear inside of a :lpy:fn:`deftest` form."
  [argv expr & args]
  (let [assertion-form (with-meta `(is ~expr) (meta &form))]
    `(template/do-template ~argv ~assertion-form ~@args)))

(defmacro testing
  "Wrapper for test cases to provide additional messaging and context around the test
  or group of tests contained inside. The value of ``msg`` will be shown in the report
  with any test failures that occur inside this block.

  ``testing`` macros may be nested. Each nested block message will be appended to the
  message from the previous block.

  ``testing`` forms must appear inside of a :lpy:fn:`deftest` form."
  [msg & body]
  `(binding [*test-section* (if *test-section*
                              (str *test-section* " :: " ~msg)
                              ~msg)
             *testing-contexts* (conj *testing-contexts* ~msg)]
     ~@body))

(defn testing-contexts-str
  "Return the current nested :lpy:fn:`testing` context."
  []
  (or *test-section* ""))

(defn testing-vars-str
  "Return a human-readable description of the current test and optional event."
  [m]
  (str "(" (apply str (interpose " " *testing-vars*)) ")"
       (if-let [line (:line m)] (str " (line " line ")") "")))

(defn ^:private test-fn-form
  [test-ns-name test-name body]
  `(fn []
     (binding [*ns*            (the-ns ~test-ns-name)
               *test-name*     ~test-name
               *testing-vars*  [~test-name]
               *test-section*  nil
               *testing-contexts* '()
               *test-failures* (volatile! [])
               *test-passes*   (volatile! 0)]
       ~@body
       (let [result# {:failures (deref *test-failures*)
                      :passes   (deref *test-passes*)}]
         (when *test-results*
           (vswap! *test-results* conj {:name ~test-name :result result#}))
         result#))))

(defmacro deftest
  "Define a new test.

  Assertions can be made with the :lpy:fn:`is` and :lpy:fn:`are` macros. Group tests
  with the :lpy:fn:`testing` macro.

  Tests defined by `deftest` will be run by default by the PyTest test runner using
  Basilisp's builtin PyTest hook."
  [name-sym & body]
  (when *load-tests*
    (let [test-name-sym (vary-meta name-sym assoc ::test true)
          test-name-str (name test-name-sym)
          test-ns-name  `(quote ~(symbol (name *ns*)))
          v             (gensym "v")]
      `(let [~v (def ~test-name-sym
                  ~(test-fn-form test-ns-name test-name-str body))]
         ;; Clojure.test exposes the test body through ordinary :test metadata
         ;; as well as its runner's internal marker.
         (alter-meta! ~v assoc :test (var-get ~v))
         ~v))))

(defmacro deftest-
  "Like :lpy:fn:`deftest`, but creates a private test Var."
  [name-sym & body]
  (when *load-tests*
    (let [test-name-sym (vary-meta name-sym assoc ::test true :private true)
          test-name-str (name test-name-sym)
          test-ns-name  `(quote ~(symbol (name *ns*)))
          v             (gensym "v")]
      `(let [~v (def ~test-name-sym
                  ~(test-fn-form test-ns-name test-name-str body))]
         (alter-meta! ~v assoc :test (var-get ~v))
         ~v))))

(defmacro with-test
  "Associate test assertions with a definition. The definition must return a Var.
  When :lpy:var:`*load-tests*` is false, only evaluate the definition."
  [definition & body]
  (let [v            (gensym "v")
        test-ns-name `(quote ~(symbol (name *ns*)))
        test-name    `(name (:name (meta ~v)))]
    (if *load-tests*
      `(let [~v ~definition]
         (alter-meta! ~v assoc
                      ::test ~(test-fn-form test-ns-name test-name body)
                      :test ~(test-fn-form test-ns-name test-name body))
         ~v)
      definition)))

(defmacro set-test
  "Associate test assertions with an existing Var."
  [name-sym & body]
  (when *load-tests*
    (let [v            (gensym "v")
          test-ns-name `(quote ~(symbol (name *ns*)))
          test-name    `(name (:name (meta ~v)))]
      `(let [~v (var ~name-sym)]
         (alter-meta! ~v assoc
                      ::test ~(test-fn-form test-ns-name test-name body)
                      :test ~(test-fn-form test-ns-name test-name body))
         ~v))))

(defn ^:private empty-summary
  []
  {:test 0 :pass 0 :fail 0 :error 0})

(defn ^:private merge-summaries
  [left right]
  (merge-with + left right))

(defn ^:private summarize-test-result
  [result]
  (reduce (fn [summary failure]
            (case (:type failure)
              :failure (update summary :fail inc)
              :error   (update summary :error inc)
              summary))
          {:test  1
           :pass  (or (:passes result) 0)
           :fail  0
           :error 0}
          (:failures result)))

(defn ^:private report-test-failure
  [test-name failure]
  (let [type      (:type failure)
        line      (:line failure)]
    (println (str "\n" (if (= :error type) "ERROR" "FAIL")
                  " in (" test-name ")"
                  (if line (str " (line " line ")") "")))
    (when (:test-section failure)
      (println (:test-section failure)))
    (println (:message failure))
    (println "expected:" (pr-str (:expected failure)))
    (println "  actual:" (pr-str (:actual failure)))))

(defn ^:private fixture-error-summary
  [e]
  (report {:type :fixture-error :exception e})
  {:test 0 :pass 0 :fail 0 :error 1})

(defn ^:private run-with-fixtures
  [fixtures f]
  (let [result (volatile! nil)]
    (try
      (with-fixtures [(join-fixtures fixtures)]
        (vreset! result (f)))
      (deref result)
      (catch python/Exception e
        (merge-summaries
         (or (deref result) (empty-summary))
         (fixture-error-summary e))))))

(defn ^:private test-function
  [v]
  (let [metadata (meta v)
        test     (::test metadata)]
    (cond
      (fn? test) test
      test (var-get v)
      :else (:test metadata))))

(defn test-var
  "Run a Var's ``:test`` metadata function with Clojure-style report events.

  Basilisp's PyTest runner additionally records a structured per-test result,
  but this low-level entry point intentionally returns the same report-driven
  behavior expected by Clojure.test extensions.
  "
  [v]
  (when-let [test (test-function v)]
    (binding [*testing-vars* (conj *testing-vars* v)]
      (do-report {:type :begin-test-var :var v})
      (inc-report-counter :test)
      (try
        (test)
        (catch python/Exception e
          (do-report {:type :error
                      :message "Uncaught exception, not in assertion."
                      :expected nil
                      :actual e})))
      (do-report {:type :end-test-var :var v}))))

(defn ^:private run-test-var*
  [v]
  (try
    (let [result ((test-function v))]
      (doseq [failure (:failures result)]
        (when *test-output*
          (report-test-failure (:name (meta v)) failure)))
      (summarize-test-result result))
    (catch python/Exception e
      (report {:type :test-error
               :test-name (:name (meta v))
               :exception e})
      {:test 1 :pass 0 :fail 0 :error 1})))

(defn ^:private test-var?
  [v]
  (boolean (or (::test (meta v)) (:test (meta v)))))

(defn test-vars
  "Run the supplied test Vars with the ``:once`` and ``:each`` fixtures declared
  by their namespaces. Return a summary map."
  [vars]
  (reduce
   (fn [summary [ns vars]]
     (let [ns-meta       (meta ns)
           once-fixtures (or (::once-fixtures ns-meta) [])
           each-fixtures (or (::each-fixtures ns-meta) [])
           ns-summary    (run-with-fixtures
                          once-fixtures
                          (fn []
                            (reduce
                             (fn [summary v]
                               (merge-summaries
                                summary
                                (run-with-fixtures
                                 each-fixtures
                                 #(run-test-var* v))))
                             (empty-summary)
                             vars)))]
       (merge-summaries summary ns-summary)))
   (empty-summary)
   (group-by #(:ns (meta %)) (filter test-var? vars))))

(defn test-all-vars
  "Run all ``deftest`` Vars in namespace ``ns`` and return a summary map."
  [ns]
  (test-vars (vals (ns-interns (the-ns ns)))))

(defn test-ns
  "Run a namespace's tests and return a summary map.

  When ``ns`` defines ``test-ns-hook``, call that hook instead of automatically
  selecting test Vars. Direct ``deftest`` calls made by the hook are aggregated."
  [ns]
  (binding [*report-counters* (ref *initial-report-counters*)]
    (let [ns (the-ns ns)]
      (when *test-output*
        (println "Testing" (.-name ns)))
      (if-let [hook (get (ns-interns ns) 'test-ns-hook)]
        (binding [*test-results* (volatile! [])]
          (let [hook-outcome (try
                               {:result ((var-get hook))}
                               (catch python/Exception e
                                 {:error e}))
                results      (deref *test-results*)
                test-summary (reduce (fn [summary {:keys [name result]}]
                                       (doseq [failure (:failures result)]
                                         (when *test-output*
                                           (report-test-failure name failure)))
                                       (merge-summaries summary
                                                        (summarize-test-result result)))
                                     (empty-summary)
                                     results)
                hook-summary (cond
                               (:error hook-outcome)
                               (do
                                 (report {:type :hook-error
                                          :exception (:error hook-outcome)})
                                 {:test 0 :pass 0 :fail 0 :error 1})

                               (seq results) (empty-summary)
                               (map? (:result hook-outcome))
                               (summarize-test-result (:result hook-outcome))
                               :else (empty-summary))]
            (merge-summaries test-summary hook-summary)))
        (test-all-vars ns)))))

(defn ^:private report-summary
  [summary]
  (println (str "\nRan " (:test summary) " tests containing "
                (+ (:pass summary) (:fail summary) (:error summary))
                " assertions."))
  (println (:fail summary) "failures," (:error summary) "errors."))

(defmethod report :fixture-error
  [m]
  (inc-report-counter :error)
  (when *test-output*
    (println "ERROR in test fixture:" (python/repr (:exception m)))))

(defmethod report :test-error
  [m]
  (inc-report-counter :error)
  (when *test-output*
    (println (str "ERROR in (" (:test-name m) "): "
                  (python/repr (:exception m))))))

(defmethod report :hook-error
  [m]
  (inc-report-counter :error)
  (when *test-output*
    (println "ERROR in test-ns-hook:" (python/repr (:exception m)))))

(defmethod report :summary
  [summary]
  (when *test-output*
    (report-summary summary)))

(defn run-test-var
  "Run a single test Var with its namespace fixtures and print a summary."
  [v]
  (let [summary (assoc (test-vars [v]) :type :summary)]
    (report summary)
    summary))

(defmacro run-test
  "Run a single test named by ``test-symbol``."
  [test-symbol]
  `(run-test-var (var ~test-symbol)))

(defn ^:private run-namespaces
  [namespaces]
  (let [summary (assoc (reduce merge-summaries
                               (empty-summary)
                               (map test-ns namespaces))
                       :type :summary)]
    (report summary)
    summary))

(defn run-tests
  "Run all tests in the supplied namespaces and print a summary. Defaults to the
  current namespace when called with no arguments."
  ([]
   (run-namespaces [*ns*]))
  ([& namespaces]
   (run-namespaces namespaces)))

(defn run-all-tests
  "Run tests in all loaded namespaces. With ``re`` provided, only test namespace
  names that fully match the regular expression."
  ([]
   (run-namespaces (all-ns)))
  ([re]
   (run-namespaces
    (filter #(re-matches re (str (.-name %))) (all-ns)))))

(defn successful?
  "Return ``true`` when a test summary contains no failures or errors."
  [summary]
  (and (zero? (:fail summary 0))
       (zero? (:error summary 0))))
