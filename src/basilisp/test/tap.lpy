(ns basilisp.test.tap
  "Test Anything Protocol reporting for ``basilisp.test``."
  (:require
   [basilisp.string :as str]
   [basilisp.test :as t]))

(defn print-tap-plan
  "Print a TAP plan line for ``n`` assertion events."
  [n]
  (println (str "1.." n)))

(defn print-tap-diagnostic
  "Print ``data`` as one or more TAP diagnostic lines."
  [data]
  (doseq [line (str/split-lines (str data))]
    (println "#" line)))

(defn print-tap-pass
  "Print a TAP ``ok`` line."
  [msg]
  (println "ok" msg))

(defn print-tap-fail
  "Print a TAP ``not ok`` line."
  [msg]
  (println "not ok" msg))

(defn print-diagnostics
  [data]
  (when (seq t/*testing-contexts*)
    (print-tap-diagnostic (t/testing-contexts-str)))
  (when (:message data)
    (print-tap-diagnostic (:message data)))
  (print-tap-diagnostic (str "expected:" (pr-str (:expected data))))
  (print-tap-diagnostic (str "  actual:" (pr-str (:actual data)))))

(defn- test-description
  [data]
  (str "(" (apply str (interpose " " t/*testing-vars*)) ")"
       " (" (:file data "") ":" (:line data "") ")"))

(defmulti ^:dynamic tap-report :type)

(defmethod tap-report :pass
  [data]
  (t/with-test-out
   (t/record-report! data)
   (t/inc-report-counter :pass)
   (print-tap-pass (test-description data))
   (print-diagnostics data)))

(defmethod tap-report :fail
  [data]
  (t/with-test-out
   (t/record-report! data)
   (t/inc-report-counter :fail)
   (print-tap-fail (test-description data))
   (print-diagnostics data)))

(defmethod tap-report :failure
  [data]
  (t/with-test-out
   (t/record-report! data)
   (t/inc-report-counter :fail)
   (print-tap-fail (test-description data))
   (print-diagnostics data)))

(defmethod tap-report :error
  [data]
  (t/with-test-out
   (t/record-report! data)
   (t/inc-report-counter :error)
   (print-tap-fail (test-description data))
   (print-diagnostics data)))

(defmethod tap-report :fixture-error
  [data]
  (t/with-test-out
   (print-tap-fail "fixture")
   (print-tap-diagnostic (python/str (:exception data)))))

(defmethod tap-report :test-error
  [data]
  (t/with-test-out
   (print-tap-fail (str "(" (:test-name data) ")"))
   (print-tap-diagnostic (python/str (:exception data)))))

(defmethod tap-report :hook-error
  [data]
  (t/with-test-out
   (print-tap-fail "test-ns-hook")
   (print-tap-diagnostic (python/str (:exception data)))))

(defmethod tap-report :summary
  [data]
  (t/with-test-out
   (print-tap-plan (+ (:pass data) (:fail data) (:error data)))))

(defmethod tap-report :default
  [data]
  (t/with-test-out
   (print-tap-diagnostic (pr-str data))))

(defmacro with-tap-output
  "Evaluate ``body`` with TAP reporting and no human test-runner output."
  [& body]
  `(binding [t/report tap-report
             t/*test-output* false]
     ~@body))
