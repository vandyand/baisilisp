(ns basilisp.test.check.rose-tree
  (:refer-clojure :exclude [filter remove seq])
  (:import [basilisp.test.check._impl :as impl]))

(def RoseTree impl/RoseTree)
(defn ->RoseTree [root children] (impl/RoseTree root children))
(def root impl/root)
(def children impl/children)
(def make-rose impl/make_rose)
(def pure impl/rose_pure)
(def fmap impl/rose_fmap)
(def join impl/rose_join)
(def bind impl/rose_bind)
(def filter impl/rose_filter)
(def permutations impl/rose_permutations)
(def zip impl/rose_zip)
(def remove impl/rose_remove)
(def shrink impl/rose_shrink)
(def shrink-vector impl/rose_shrink_vector)
(def collapse impl/rose_collapse)
(def seq impl/rose_seq)
