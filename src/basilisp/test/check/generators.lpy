(ns basilisp.test.check.generators
  (:refer-clojure :exclude [byte int vector list hash-map map keyword char boolean
                            shuffle not-empty symbol set sorted-set double let])
  (:import [basilisp.test.check._impl :as impl]))

(def Generator impl/Generator)
(def ->Generator impl/Generator)
(defn map->Generator [m] (impl/Generator (:gen m)))
(def generator? impl/generator_q)
(def call-gen impl/call_gen)
(def gen-pure impl/gen_pure)
(def gen-fmap impl/gen_fmap)
(def gen-bind impl/gen_bind)
(def fmap impl/fmap)
(def return impl/return_)
(def bind impl/bind)
(def make-size-range-seq impl/make_size_range_seq)
(def sample-seq impl/sample_seq)
(def sample impl/sample)
(def generate impl/generate)
(def sized impl/sized)
(def resize impl/resize)
(def scale impl/scale)
(def choose impl/choose)
(def one-of impl/one_of)
(def frequency impl/frequency)
(def elements impl/elements)
(def such-that impl/such_that)
(def not-empty impl/not_empty)
(def no-shrink impl/no_shrink)
(def shrink-2 impl/shrink_2)
(def tuple impl/tuple_gen)
(def vector impl/vector)
(def list impl/list_gen)
(def shuffle impl/shuffle)
(def hash-map impl/hash_map)
(def vector-distinct impl/vector_distinct)
(def list-distinct impl/list_distinct)
(def vector-distinct-by impl/vector_distinct_by)
(def list-distinct-by impl/list_distinct_by)
(def set impl/set_gen)
(def sorted-set impl/sorted_set)
(def map impl/map_gen)
(def large-integer* impl/large_integer_star)
(def double* impl/double_star)
(def recursive-gen impl/recursive_gen)
(def container-type impl/container_type)

(def boolean impl/boolean)
(def nat impl/nat)
(def small-integer impl/small_integer)
(def int impl/integer)
(def byte impl/byte)
(def size-bounded-bigint impl/size_bounded_bigint)
(def pos-int impl/pos_int)
(def neg-int impl/neg_int)
(def s-pos-int impl/s_pos_int)
(def s-neg-int impl/s_neg_int)
(def large-integer impl/large_integer)
(def double impl/double)
(def bytes impl/bytes)
(def char impl/char)
(def char-ascii impl/char_ascii)
(def char-alphanumeric impl/char_alphanumeric)
(def char-alpha-numeric impl/char_alphanumeric)
(def char-alpha impl/char_alpha)
(def string impl/string)
(def string-ascii impl/string_ascii)
(def string-alphanumeric impl/string_alphanumeric)
(def string-alpha-numeric impl/string_alphanumeric)
(def keyword impl/keyword)
(def keyword-ns impl/keyword_ns)
(def symbol impl/symbol)
(def symbol-ns impl/symbol_ns)
(def ratio impl/ratio)
(def uuid impl/uuid)
(def simple-type impl/simple_type)
(def simple-type-printable impl/simple_type_printable)
(def simple-type-equatable impl/simple_type_equatable)
(def simple-type-printable-equatable impl/simple_type_printable_equatable)
(def any impl/any)
(def any-printable impl/any_printable)
(def any-equatable impl/any_equatable)
(def any-printable-equatable impl/any_printable_equatable)

(defmacro let
  [bindings & body]
  (assert (vector? bindings) "First arg to gen/let must be a vector of bindings")
  (assert (even? (count bindings)) "gen/let requires an even number of forms")
  (if (empty? bindings)
    `(clojure.core/let [value# (do ~@body)]
       (if (basilisp.test.check.generators/generator? value#)
         value#
         (basilisp.test.check.generators/return value#)))
    (clojure.core/let [[binding generator & rest] bindings]
      `(basilisp.test.check.generators/bind ~generator
         (fn [~binding]
           (basilisp.test.check.generators/let [~@rest] ~@body))))))
