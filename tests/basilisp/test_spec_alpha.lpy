(ns tests.basilisp.test-spec-alpha
  (:require
   [basilisp.spec.alpha :as s]
   [basilisp.test :refer [deftest is]]))

(def name-key :tests.spec/name)
(def age-key :tests.spec/age)

(s/def name-key string?)
(s/def age-key #(and (int? %) (<= 0 %)))

(deftest named-predicate-and-explain-data-test
  (is (s/valid? name-key "Ada"))
  (is (not (s/valid? name-key 42)))
  (is (= "Ada" (s/conform name-key "Ada")))
  (is (= s/invalid (s/conform name-key 42)))
  (let [problems (:basilisp.spec.alpha/problems (s/explain-data name-key 42))
        problem  (first problems)]
    (is (= 1 (count problems)))
    (is (= [] (:path problem)))
    (is (= 42 (:val problem)))
    (is (= [name-key] (:via problem)))
    (is (= [] (:in problem)))))

(deftest composition-and-conforming-test
  (let [positive-even (s/and int? pos? even?)
        choice        (s/or :name string? :age age-key)]
    (is (s/valid? positive-even 8))
    (is (not (s/valid? positive-even 3)))
    (is (= [:name "Ada"] (s/conform choice "Ada")))
    (is (= [:age 42] (s/conform choice 42)))
    (is (= s/invalid (s/conform choice :invalid)))
    (is (s/valid? (s/nilable string?) nil))))

(deftest collection-map-and-key-specs-test
  (let [ages       (s/coll-of age-key :kind vector? :min-count 1)
        name->age  (s/map-of string? age-key)
        person     (s/keys :req [name-key age-key])
        point      (s/tuple int? int?)]
    (is (= [1 2] (s/conform ages [1 2])))
    (is (= s/invalid (s/conform ages [1 -1])))
    (is (= {"Ada" 42} (s/conform name->age {"Ada" 42})))
    (is (= s/invalid (s/conform name->age {"Ada" -1})))
    (is (s/valid? person {name-key "Ada" age-key 42}))
    (is (not (s/valid? person {name-key "Ada"})))
    (is (= [1 2] (s/conform point [1 2])))
    (is (= s/invalid (s/conform point [1 "two"])))))

(deftest multi-spec-test
  (let [cat-key :tests.spec/cat
        dog-key :tests.spec/dog]
    (s/def :type #{cat-key dog-key})
    (s/def :lives int?)
    (s/def :barks boolean?)
    (s/def cat-key (s/keys :req [:type :lives]))
    (s/def dog-key (s/keys :req [:type :barks]))
    (let [pet (s/multi-spec :type)]
      (is (s/valid? pet {:type cat-key :lives 9}))
      (is (s/valid? pet {:type dog-key :barks true}))
      (is (not (s/valid? pet {:type cat-key :barks true}))))))

(deftest sequence-regex-spec-test
  (let [person (s/cat :name string? :age int?)]
    (is (s/valid? person ["Ada" 42]))
    (is (= {:name "Ada" :age 42}
           (s/conform person ["Ada" 42])))
    (is (= {:name "Ada" :age 42}
           (s/conform person (list "Ada" 42))))
    (is (= ["Ada" 42]
           (s/unform person {:name "Ada" :age 42})))
    (is (= s/invalid (s/conform person ["Ada" "old"])))
    (is (= [1]
           (:in (first (:basilisp.spec.alpha/problems
                         (s/explain-data person ["Ada" "old"])))))))
  (let [choice (s/alt :name string? :age int?)]
    (is (= [:name "Ada"] (s/conform choice ["Ada"])))
    (is (= [:age 42] (s/conform choice [42])))
    (is (= [42] (s/unform choice [:age 42]))))
  (let [many (s/cat :head string? :tail (s/* int?))]
    (is (= {:head "values" :tail [1 2 3]}
           (s/conform many ["values" 1 2 3])))
    (is (= [] (s/conform (s/* int?) [])))
    (is (= [1 2] (s/conform (s/+ int?) [1 2])))
    (is (= s/invalid (s/conform (s/+ int?) [])))
    (is (= nil (s/conform (s/? int?) [])))
    (is (= 1 (s/conform (s/? int?) [1])))
    (is (= s/invalid (s/conform (s/? int?) [1 2]))))
  (let [pairs (s/cat :pairs (s/+ (s/cat :x int? :y int?))
                     :end   string?)]
    (is (= {:pairs [{:x 1 :y 2} {:x 3 :y 4}] :end "done"}
           (s/conform pairs [1 2 3 4 "done"])))
    (is (= [1 2 3 4 "done"]
           (s/unform pairs {:pairs [{:x 1 :y 2} {:x 3 :y 4}] :end "done"})))
    (is (= s/invalid (s/conform pairs [1 2 "extra" "done"])))
    (is (= s/invalid (s/conform (s/alt :name string? :age int?) ["Ada" 42])))))

(deftest sequence-conjunction-spec-test
  (let [small-ints (s/& (s/+ int?) #(< (count %) 4))]
    (is (= [1 2 3] (s/conform small-ints [1 2 3])))
    (is (= s/invalid (s/conform small-ints [1 2 3 4])))
    (is (= s/invalid (s/conform small-ints [1 "two"])))))

(defn spec-function [value] value)

(deftest function-spec-registry-test
  (let [function-spec (s/fdef spec-function :args (s/cat :value int?) :ret int?)]
    (is (= function-spec (s/get-fspec (var spec-function))))
    (is (s/valid? function-spec spec-function))
    (is (not (s/valid? function-spec 42)))))

(deftest public-spec-compatibility-surface-test
  (doseq [sym '[*coll-check-limit*
                *coll-error-limit*
                *explain-out*
                *fspec-iterations*
                *recursion-limit*
                Spec
                Specize
                abbrev
                alt-impl
                amp-impl
                and-spec-impl
                cat-impl
                conform*
                def-impl
                describe*
                every-impl
                explain*
                explain-data*
                explain-printer
                fspec-impl
                gen*
                keys*
                map-spec-impl
                maybe-impl
                merge-spec-impl
                multi-spec-impl
                nilable-impl
                or-spec-impl
                regex-spec-impl
                registry
                rep+impl
                rep-impl
                spec-impl
                specize*
                tuple-impl
                unform*
                with-gen*]]
    (is (contains? (ns-publics 'basilisp.spec.alpha) sym)))
  (let [sp (s/spec int?)]
    (is (s/spec? sp))
    (is (= 1 (s/conform* sp 1)))
    (is (s/invalid? (s/conform* sp "x")))
    (is (= 1 (s/unform* sp 1)))
    (is (s/explain-data* sp [] [] [] "x"))
    (is (s/describe* sp))
    (is (s/spec? (s/specize* int?))))
  (s/def :tests.spec/compat int?)
  (is (contains? (s/registry) :tests.spec/compat))
  (is (= :tests.spec/from-def-impl
         (s/def-impl :tests.spec/from-def-impl 'int? int?)))
  (is (s/valid? :tests.spec/from-def-impl 5))
  (is (= {:x 1} (s/conform (s/cat-impl [:x] [int?] ['int?]) [1])))
  (is (= [:i 1] (s/conform (s/alt-impl [:i] [int?] ['int?]) [1])))
  (is (= [1 2] (s/conform (s/rep+impl 'int? int?) [1 2])))
  (is (= nil (s/conform (s/maybe-impl int? 'int?) []))))
