(ns tests.basilisp.core-cache-test
  (:require [basilisp.test :refer [deftest is]]
            [clojure.core.cache :as cache]
            [clojure.core.cache.wrapped :as wrapped]))

(deftest caches-are-persistent-maps-with-basic-through-contract
  (let [original (cache/basic-cache-factory {:a 1})
        changed (assoc original :b 2)]
    (is (= {:a 1} original))
    (is (= {:a 1 :b 2} changed))
    (is (= 1 (cache/lookup changed :a)))
    (is (= :missing (cache/lookup changed :missing :missing)))
    (is (contains? changed :b))
    (is (= {:cache :test} (meta (with-meta changed {:cache :test}))))
    (is (= {:a 1 :b 2} (with-meta changed {:cache :test})))
    (is (= {:a 1 :b 2 :c 3}
           (cache/through (fn [key] (if (= key :c) 3 0)) changed :c)))))

(deftest fifo-lru-and-least-used-eviction-contracts
  (let [fifo (-> (cache/fifo-cache-factory {} :threshold 2)
                 (cache/miss :a 1)
                 (cache/miss :b 2)
                 (cache/miss :c 3))
        lru  (-> (cache/lru-cache-factory {} :threshold 2)
                 (cache/miss :a 1)
                 (cache/miss :b 2)
                 (cache/hit :a)
                 (cache/miss :c 3))
        lu   (-> (cache/lu-cache-factory {} :threshold 2)
                 (cache/miss :a 1)
                 (cache/miss :b 2)
                 (cache/hit :a)
                 (cache/miss :c 3))]
    (is (= {:b 2 :c 3} fifo))
    (is (= {:a 1 :c 3} lru))
    (is (= {:a 1 :c 3} lu))
    (is (= {:a 1} (cache/evict lru :c)))))

(deftest lirs-and-wrapped-cache-contracts
  (let [lirs (-> (cache/lirs-cache-factory {} :s-history-limit 2 :q-history-limit 2)
                 (cache/miss :a 1)
                 (cache/miss :b 2)
                 (cache/miss :c 3))
        wrapped-cache (wrapped/lru-cache-factory {} :threshold 2)]
    (is (= 3 (cache/lookup lirs :c)))
    (is (= 1 (wrapped/lookup-or-miss wrapped-cache :a (fn [_] 1))))
    (is (= 1 (wrapped/lookup-or-miss wrapped-cache :a (fn [_] 99))))
    (is (= 1 (wrapped/size wrapped-cache)))
    (is (= {:a 1 :b 2}
           (wrapped/miss wrapped-cache :b 2)))))

(deftest soft-cache-is-explicitly-unavailable
  (is (contains? (ns-publics 'basilisp.core.cache) '->SoftCache))
  (is (contains? (ns-publics 'basilisp.core.cache) 'make-reference))
  (is (contains? (ns-publics 'basilisp.core.cache) 'clear-soft-cache!))
  (is (contains? (ns-publics 'basilisp.core.cache) 'defcache))
  (is (thrown? Exception (cache/soft-cache-factory {})))
  (is (thrown? python/NotImplementedError (cache/->SoftCache {} {} nil)))
  (is (thrown? python/NotImplementedError (cache/make-reference :value nil)))
  (is (thrown? python/NotImplementedError (cache/clear-soft-cache! {} {} nil))))

(deftest public-positional-cache-constructors-retain-policy
  (let [basic (cache/->BasicCache {:a 1})
        fn-cache (cache/->FnCache {:a 2} inc)
        fifo (cache/->FIFOCache {:a 1} [:a] 2)
        lru (cache/->LRUCache {:a 1} {:a 0} 0 2)
        ttl (cache/seed (cache/->TTLCacheQ {} {} [] 0 2000) {:a 1})
        lu (cache/->LUCache {:a 1} {:a 0} 2)
        lirs (cache/->LIRSCache {:a 1} {-1 -1} {-1 -1} 0 2 2)]
    (is (= 1 (cache/lookup basic :a)))
    (is (= 3 (cache/lookup fn-cache :a)))
    (is (= [[:a 1]] (vec fifo)))
    (is (= {:a 1 :b 2} (cache/miss lru :b 2)))
    (is (= 1 (cache/lookup ttl :a)))
    (is (= 1 (cache/lookup (cache/hit lu :a) :a)))
    (is (= 1 (cache/lookup lirs :a)))))
