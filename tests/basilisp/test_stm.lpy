(ns tests.basilisp.test-stm
  (:require
   [basilisp.stm :as stm]
   [basilisp.test :refer [deftest is]]))

(deftest basic-transaction-test
  (let [first  (stm/ref 1)
        second (stm/ref 2)]
    (is (= :result
           (stm/dosync
            (is (stm/in-transaction?))
            (stm/alter first + 2)
            (stm/ref-set second 6)
            :result)))
    (is (= 3 @first))
    (is (= 6 @second))))

(deftest nested-transaction-test
  (let [value (stm/ref 1)]
    (stm/dosync
     (stm/alter value inc)
     (stm/dosync (stm/alter value inc)))
    (is (= 3 @value))))

(deftest after-commit-actions-and-io-guard-test
  (let [events (atom [])
        a      (agent 0)]
    (stm/dosync
     (stm/after-commit #(swap! events conj :committed))
     (send a + 1))
    (await-agent a)
    (is (= [:committed] @events))
    (is (= 1 @a))
    (is (nil? (io!)))
    (is (thrown? python/RuntimeError
                 (stm/dosync (io!))))))

(deftest aborted-transaction-discards-agent-actions-test
  (let [a (agent 0)]
    (try
      (stm/dosync
       (send a + 1)
       (throw (python/ValueError "abort")))
      (catch python/ValueError _))
    (await-agent a)
    (is (= 0 @a))))
