(ns tests.basilisp.test-spec-test-alpha
  (:require
   [basilisp.spec.alpha :as s]
   [basilisp.spec.test.alpha :as st]
   [basilisp.test :refer [deftest is]])
  (:import hypothesis.strategies))

(defn typed-identity [value] value)
(defn invalid-return [value] "not an integer")
(defn increment [value] (+ value 1))

(s/fdef typed-identity
        :args (s/cat :value (s/with-gen int? (hypothesis.strategies/integers)))
        :ret int?)
(s/fdef invalid-return :args (s/cat :value int?) :ret int?)
(s/fdef increment
        :args (s/cat :value int?)
        :ret int?
        :fn (fn [{:keys [args ret]}] (= (+ (:value args) 1) ret)))

(deftest instruments-direct-and-var-calls
  (st/instrument (var typed-identity))
  (try
    (is (= 2 (typed-identity 2)))
    (is (= 3 ((var typed-identity) 3)))
    (is (thrown? basilisp.lang.exception/ExceptionInfo (typed-identity "bad")))
    (finally
      (st/unstrument (var typed-identity))))
  (is (= "no longer checked" (typed-identity "no longer checked"))))

(deftest instruments-return-and-relation-specs
  (st/instrument (var invalid-return) (var increment))
  (try
    (is (thrown? basilisp.lang.exception/ExceptionInfo (invalid-return 1)))
    (is (= 3 (increment 2)))
    (finally
      (st/unstrument (var invalid-return) (var increment)))))

(deftest generated-function-check-test
  (let [result (first (st/check (var typed-identity) :num-tests 10 :seed 5))]
    (is (:basilisp.spec.test.alpha/pass? result))))

(deftest public-spec-test-compatibility-surface-test
  (doseq [sym '[->sym
                abbrev-result
                check-fn
                checkable-syms
                enumerate-namespace
                instrumentable-syms
                summarize-results
                with-instrument-disabled]]
    (is (contains? (ns-publics 'basilisp.spec.test.alpha) sym)))
  (is (= 'tests.basilisp.test-spec-test-alpha/typed-identity
         (st/->sym (var typed-identity))))
  (is (= 'tests.basilisp.test-spec-test-alpha/typed-identity
         (st/->sym 'tests.basilisp.test-spec-test-alpha/typed-identity)))
  (is (= {:total 0} (st/summarize-results [])))
  (is (contains? (st/enumerate-namespace 'tests.basilisp.test-spec-test-alpha)
                 'tests.basilisp.test-spec-test-alpha/typed-identity))
  (is (= :ok (st/with-instrument-disabled :ok))))
