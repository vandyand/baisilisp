(ns tests.basilisp.core.test-server
  (:require [basilisp.test :refer [deftest is]]
            [basilisp.core.server :as server]
            [basilisp.contrib.prepl :as prepl]
            [basilisp.string :as str]
            [clojure.core.server :as clj-server])
  (:import io
           socket))

(defn- echo-accept [prefix]
  (let [line (.readline *in*)]
    (.write *out* (str prefix line))
    (.flush *out*)))

(defn- self-stopping-accept []
  (server/stop-server)
  (.write *err* "stopping\n")
  (.flush *err*))

(defn- server-port [server]
  (nth (.-server_address server) 1))

(defn- request [port text]
  (with-open [client (socket/create_connection (python/tuple ["127.0.0.1" port]) ** :timeout 2)
              out    (io/TextIOWrapper (.makefile client "wb") ** :encoding "utf-8" :write-through true)
              in     (io/TextIOWrapper (.makefile client "rb") ** :encoding "utf-8")]
    (.write out text)
    (.flush out)
    (.readline in)))

(defn- repl-request [port text]
  (with-open [client (socket/create_connection (python/tuple ["127.0.0.1" port]) ** :timeout 2)
              out    (io/TextIOWrapper (.makefile client "wb") ** :encoding "utf-8" :write-through true)
              in     (io/TextIOWrapper (.makefile client "rb") ** :encoding "utf-8")]
    (.write out text)
    (.flush out)
    (.shutdown client socket/SHUT_WR)
    (.read in)))

(deftest start-stop-and-import-path-test
  (let [name "core-server-basic"
        s    (server/start-server {:port 0 :name name :accept echo-accept :args ["echo:"]})]
    (try
      (is (= "echo:hello\n" (request (server-port s) "hello\n")))
      (is (= true (server/stop-server name)))
      (is (nil? (server/stop-server name)))
      (finally
        (server/stop-server name))))
  (let [name "core-server-alias"
        s    (clj-server/start-server {:port 0 :name name :accept echo-accept :args ["alias:"]})]
    (try
      (is (= "alias:ok\n" (request (server-port s) "ok\n")))
      (finally
        (clj-server/stop-server name)))))

(deftest server-option-and-property-validation-test
  (is (thrown? python/ValueError
               (server/start-server {:port -1 :name "bad-port" :accept echo-accept})))
  (is (thrown? python/ValueError
               (server/start-server {:port 0 :name "" :accept echo-accept})))
  (is (thrown? python/ValueError
               (server/start-server {:port 0 :name "bad-accept" :accept 1})))
  (is (thrown? python/ValueError
               (server/start-servers {"clojure.server.bad" {:port 0}}))))

(deftest server-session-stop-and-bind-err-test
  (let [name "core-server-self-stop"
        s    (server/start-server {:port 0 :name name :accept self-stopping-accept})]
    (try
      (is (= "stopping\n" (request (server-port s) "wake\n")))
      (is (nil? (server/stop-server name)))
      (finally
        (server/stop-server name)))))

(deftest server-atomic-name-race-and-stop-all-test
  (let [name    "core-server-race"
        started (mapv (fn [_]
                        (future
                          (try
                            (server/start-server {:port 0 :name name :accept echo-accept :args [""]})
                            (catch python/ValueError _ nil))))
                      (range 24))
        winners (vec (filter identity (map deref started)))]
    (try
      (is (= 1 (count winners)))
      (is (= true (server/stop-server name)))
      (is (nil? (server/stop-server name)))
      (finally
        (server/stop-servers)))))

(deftest server-start-servers-edn-symbol-test
  (let [name "from-properties"]
    (try
      (is (nil? (server/start-servers
                 {"clojure.server.from-properties"
                  "{:port 0 :accept tests.basilisp.core.test-server/echo-accept :args [\"prop:\"]}"})))
      (is (= true (server/stop-server name)))
      (finally
        (server/stop-server name)))))

(deftest core-server-io-prepl-end-to-end-test
  (let [name   "core-server-io-prepl"
        s      (server/start-server {:port 0 :name name :accept server/io-prepl})
        events (atom [])]
    (try
      (prepl/remote-prepl "127.0.0.1" (server-port s) (io/StringIO "(+ 20 22)\n")
                          #(swap! events conj %))
      (is (= :ret (:tag (first @events))))
      (is (= 42 (:val (first @events))))
      (finally
        (server/stop-server name)))))

(deftest core-server-repl-read-and-quit-test
  (binding [*in* (io/StringIO "42")]
    (is (= 42 (server/repl-read :prompt :exit))))
  (binding [*in* (io/StringIO ":repl/quit")]
    (is (= :exit (server/repl-read :prompt :exit)))))

(deftest core-server-repl-end-to-end-test
  (let [name "core-server-repl"
        s    (server/start-server {:port 0 :name name :accept server/repl})]
    (try
      (let [response (repl-request (server-port s)
                                   "(+ 20 22)\n(+ *1 1)\n(/ 1 0)\n(+ 6 1)\n:repl/quit\n(+ 100 1)\n")]
        (is (str/includes? response "user=> "))
        (is (str/includes? response "42"))
        (is (str/includes? response "43"))
        (is (str/includes? response "builtins.ZeroDivisionError"))
        (is (str/includes? response "7"))
        (is (not (str/includes? response "101"))))
      (is (str/includes? (repl-request (server-port s) "(+ 4 5)\n:repl/quit\n")
                         "9"))
      (finally
        (server/stop-server name)))))
