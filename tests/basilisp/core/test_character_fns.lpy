(ns tests.basilisp.core.test-character-fns
  (:require
   [basilisp.test :refer [deftest are is]]))

(deftest character-type-and-conversion-test
  (is (char? \a))
  (is (not (string? \a)))
  (is (not (char? "a")))
  (is (not= \a "a"))
  (is (= \A (char 65)))
  (is (= \a (char \a)))
  (is (= 97 (int \a)))
  (is (= "a" (str \a)))
  (is (thrown? python/ValueError (char "a"))))

(deftest character-sequence-and-collection-test
  (is (= [\a \b \Ω] (vec "abΩ")))
  (is (= [\a \b \Ω] (into [] "abΩ")))
  (is (= #{\a \b} (set "aba")))
  (is (= \b (nth "ab" 1)))
  (is (= \a (get "ab" 0)))
  (is (= [\a \b] (vec (seq "ab"))))
  (is (= :char (get {\a :char "a" :string} \a)))
  (is (= :string (get {\a :char "a" :string} "a"))))

(deftest utf16-string-indexing-and-character-coercion-test
  (let [s "a😀𝄞b"]
    (is (= 6 (count s)))
    (is (= [97 55357 56832 55348 56606 98] (mapv int s)))
    (is (= [97 55357 56832 55348 56606 98] (mapv int (vec s))))
    (is (= 55357 (int (nth s 1))))
    (is (= 56832 (int (get s 2))))
    (is (= [55357 56832] (mapv int (subs s 1 3))))
    (is (= [55357] (mapv int (subs s 1 2))))
    (is (= [56832] (mapv int (subs s 2 3))))
    (is (= :missing (nth s -1 :missing)))
    (is (= :missing (get s -1 :missing)))
    (is (thrown? python/IndexError (nth s -1)))
    (is (thrown? python/IndexError (subs s -1)))
    (is (thrown? python/IndexError (subs s 2 1)))
    (is (thrown? python/IndexError (subs s 0 7)))
    (is (false? (contains? s -1)))
    (is (true? (contains? s 5)))
    (is (false? (contains? s 6))))
  (is (= 65535 (int (char 65535))))
  (is (thrown? python/ValueError (char 65536)))
  (is (thrown? python/ValueError (char -1)))
  (is (thrown? python/ValueError (char true)))
  (is (= 0 (int (unchecked-char 65536))))
  (is (= 65535 (int (unchecked-char -1)))))
