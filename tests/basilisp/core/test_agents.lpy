(ns tests.basilisp.core.test-agents
  (:import time
           threading
           random
           [basilisp.lang.futures :as futures])
  (:require
   [basilisp.test :refer [deftest is]]))

(def ^:dynamic *agent-context-probe* :root)

(deftest agent-serial-state-test
  (let [a       (agent 0)
        _send   (send a + 1)
        _send-off (send-off a + 2)
        waited  (await-agent a)
        state   @a
        error   (agent-error a)]
    (is (nil? waited))
    (is (= 3 state))
    (is (nil? error))))

(deftest agent-failure-test
  (let [a        (agent 0)
        _failed  (send a (fn [_] (throw (python/ValueError "bad action"))))
        _waited  (await-agent a)
        error    (agent-error a)
        state    @a]
    (is (instance? python/ValueError error))
    (is (= [error] (agent-errors a)))
    (is (= 0 state))
    (is (thrown? python/RuntimeError (send a + 1)))
    (clear-agent-errors a)
    (restart-agent a)
    (send a + 1)
    (await-agent a)
    (is (= 1 @a))
    (is (nil? (agent-errors a)))))

(deftest agent-continue-mode-test
  (let [a        (agent 0 :error-mode :continue)
        _failed  (send a (fn [_] (throw (python/ValueError "bad action"))))
        _sent    (send a + 1)
        _waited  (await-agent a)
        state    @a
        error    (agent-error a)]
    (is (= 1 state))
    (is (instance? python/ValueError error))))

(deftest current-agent-binding-test
  (let [a      (agent nil)
        b      (agent nil)
        seen-a (promise)
        seen-b (promise)]
    ;; The executing target wins over a caller's arbitrary dynamic binding.
    (binding [*agent* :caller *agent-context-probe* :captured]
      (send a (fn [state]
                (deliver seen-a [(identical? a *agent*) *agent-context-probe*])
                (send b (fn [next-state]
                          (deliver seen-b [(identical? b *agent*) *agent-context-probe*])
                          next-state))
                state)))
    (clojure.core/await a b)
    (is (= [true :captured] (deref seen-a 1000 false)))
    (is (= [true :captured] (deref seen-b 1000 false)))
    (is (nil? *agent*))))

(deftest send-via-test
  (let [executor (futures/ThreadPoolExecutor ** :max-workers 1 :thread-name-prefix "agent-via")
        a        (agent nil)]
    (try
      (send-via executor a (fn [_] (.-name (threading/current_thread))))
      (await-agent a)
      (is (.startswith @a "agent-via"))
      (finally
        (.shutdown executor)))))

(deftest await1-waits-for-pending-action-test
  (let [a       (agent 0)
        started (promise)
        release (promise)
        _sent   (send a (fn [state]
                          (deliver started true)
                          (deref release)
                          (inc state)))
        _ready  (deref started 1000 false)
        waiter  (future (await1 a))]
    (time/sleep 0.05)
    (is (false? (future-done? waiter)))
    (deliver release true)
    (is (identical? a (deref waiter 1000 :timeout)))
    (is (true? (future-done? waiter)))))

(deftest agent-await-for-test
  (let [a       (agent 0)
        _sent   (send a (fn [state]
                          (time/sleep 0.1)
                          (inc state)))
        timed   (await-for 1 a)
        waited  (await-for 1000 a)
        state   @a]
    (is (false? timed))
    (is (true? waited))
    (is (= 1 state))))

(deftest restart-agent-can-set-nil-state-test
  (let [a        (agent 1)
        _restart (restart-agent a nil)]
    (is (nil? @a))))

(deftest restart-agent-clear-actions-option-test
  (let [a        (agent 0)
        _failed  (send a (fn [_]
                           (time/sleep 0.1)
                           (throw (python/ValueError "bad action"))))
        _queued  (send a + 1)
        _waited  (await-agent a)
        _restart (restart-agent a 2 :clear-actions true)
        _waited2 (await-agent a)]
    (is (= 2 @a))))

(deftest clojure-agent-waits-and-context-guards-test
  (let [a       (agent 0)
        _sent   (send a + 1)
        waited  (clojure.core/await a)]
    (is (nil? waited))
    (is (= 1 @a))
    (is (thrown? python/RuntimeError
                 (dosync (clojure.core/await a)))))
  (let [a       (agent 0)
        blocked (promise)
        release (promise)
        _sent   (send a (fn [state]
                          (deliver blocked true)
                          (deref release)
                          (inc state)))]
    (is (true? (deref blocked 1000 false)))
    (is (false? (await-for 1 a)))
    (deliver release true)
    (is (true? (await-for 1000 a))))
  (let [a        (agent 0)
        _failed  (send a (fn [_] (throw (python/ValueError "wait failure"))))
        _settled (await-agent a)]
    (is (thrown? python/RuntimeError (clojure.core/await a)))
    (is (thrown? python/RuntimeError (await-for 1 a)))
    (is (identical? a (await1 a))))
  (let [a       (agent 0)
        result  (promise)
        _sent   (send a (fn [state]
                          (try
                            (clojure.core/await a)
                            (deliver result :not-rejected)
                            (catch python/Exception _
                              (deliver result :rejected)))
                          state))]
    (await-agent a)
    (is (= :rejected (deref result 1000 :timeout)))))

(deftest global-agent-executors-preserve-dispatch-ownership-test
  (let [old-send     *agent-send-executor*
        old-send-off *agent-send-off-executor*
        send-a       (futures/ThreadPoolExecutor ** :max-workers 1 :thread-name-prefix "lifecycle-send-a")
        send-b       (futures/ThreadPoolExecutor ** :max-workers 1 :thread-name-prefix "lifecycle-send-b")
        off-a        (futures/ThreadPoolExecutor ** :max-workers 1 :thread-name-prefix "lifecycle-off-a")
        off-b        (futures/ThreadPoolExecutor ** :max-workers 1 :thread-name-prefix "lifecycle-off-b")
        started      (promise)
        release      (promise)
        a            (agent [])]
    (try
      (is (identical? send-a (set-agent-send-executor! send-a)))
      (is (identical? off-a (set-agent-send-off-executor! off-a)))
      (send a (fn [state]
                (deliver started true)
                (deref release)
                (conj state (.-name (threading/current_thread)))))
      (is (true? (deref started 1000 false)))
      ;; This action was queued before the replacement and must retain send-a.
      (send a (fn [state] (conj state (.-name (threading/current_thread)))))
      (set-agent-send-executor! send-b)
      (send a (fn [state] (conj state (.-name (threading/current_thread)))))
      (set-agent-send-off-executor! off-b)
      (send-off a (fn [state] (conj state (.-name (threading/current_thread)))))
      (deliver release true)
      (clojure.core/await a)
      (is (= ["lifecycle-send-a"
              "lifecycle-send-a"
              "lifecycle-send-b"
              "lifecycle-off-b"]
             (mapv #(first (.rsplit % "_" 1)) @a)))
      (is (= 0 (release-pending-sends)))
      (finally
        (set-agent-send-executor! old-send)
        (set-agent-send-off-executor! old-send-off)
        (.shutdown send-a)
        (.shutdown send-b)
        (.shutdown off-a)
        (.shutdown off-b)))))

(deftest global-agent-executor-seeded-switch-stress-test
  (let [old-send     *agent-send-executor*
        old-send-off *agent-send-off-executor*
        send-a       (futures/ThreadPoolExecutor ** :max-workers 3 :thread-name-prefix "fuzz-send-a")
        send-b       (futures/ThreadPoolExecutor ** :max-workers 3 :thread-name-prefix "fuzz-send-b")
        off-a        (futures/ThreadPoolExecutor ** :max-workers 3 :thread-name-prefix "fuzz-off-a")
        off-b        (futures/ThreadPoolExecutor ** :max-workers 3 :thread-name-prefix "fuzz-off-b")
        executors    [[send-a "fuzz-send-a" false]
                      [send-b "fuzz-send-b" false]
                      [off-a "fuzz-off-a" true]
                      [off-b "fuzz-off-b" true]]
        source       (random/Random 20260730)
        agents       (vec (repeatedly 9 #(agent [])))]
    (try
      (dotimes [i 240]
        (let [[executor prefix send-off?] (nth executors (.randint source 0 3))
              target                    (nth agents (.randint source 0 8))]
          (if send-off?
            (set-agent-send-off-executor! executor)
            (set-agent-send-executor! executor))
          ((if send-off? send-off send)
           target
           (fn [state index expected-prefix]
             (conj state [index expected-prefix (.-name (threading/current_thread))]))
           i
           prefix)))
      (apply clojure.core/await agents)
      (let [events (vec (mapcat deref agents))]
        (is (= 240 (count events)))
        (is (= (set (range 240)) (set (map first events))))
        (is (every? (fn [[_ prefix thread-name]]
                      (.startswith thread-name prefix))
                    events)))
      (finally
        (set-agent-send-executor! old-send)
        (set-agent-send-off-executor! old-send-off)
        (.shutdown send-a)
        (.shutdown send-b)
        (.shutdown off-a)
        (.shutdown off-b)))))

(deftest shutdown-agents-stops-current-global-executors-test
  (let [old-send     *agent-send-executor*
        old-send-off *agent-send-off-executor*
        send-pool    (futures/ThreadPoolExecutor ** :max-workers 1 :thread-name-prefix "shutdown-send")
        off-pool     (futures/ThreadPoolExecutor ** :max-workers 1 :thread-name-prefix "shutdown-off")
        started      (promise)
        release      (promise)
        a            (agent 0)]
    (try
      (set-agent-send-executor! send-pool)
      (set-agent-send-off-executor! off-pool)
      (send a (fn [state]
                (deliver started true)
                (deref release)
                (inc state)))
      (is (true? (deref started 1000 false)))
      (is (nil? (shutdown-agents)))
      (deliver release true)
      (await-agent a)
      (is (= 1 @a))
      (is (thrown? python/RuntimeError (send a inc)))
      (finally
        (set-agent-send-executor! old-send)
        (set-agent-send-off-executor! old-send-off)
        (.shutdown send-pool)
        (.shutdown off-pool)))))
