(ns tests.basilisp.core.test-taps
  (:require
   [basilisp.test :refer [deftest is]])
  (:import threading))

(defn- force-contested-update
  [swap-fn]
  (let [value   (atom 0)
        entered (threading/Event)
        release (threading/Event)
        worker  (future
                  (swap-fn value
                           (fn [old-value]
                             (.set entered)
                             (.wait release)
                             (inc old-value))))]
    (.wait entered)
    (swap! value inc)
    (.set release)
    [@worker @value]))

(deftest swap-retries-preserve-variadic-arguments-test
  ;; Force the first update to lose its compare-and-set race. Both functions
  ;; must retry with their original argument list, rather than treating it as
  ;; a new argument to the supplied updater.
  (is (= [2 2] (force-contested-update swap!)))
  (is (= [[2 1] 2] (force-contested-update swap-vals!))))

(deftest tap-test
  (let [tap-queue (var-get (find-var 'basilisp.core/tap-queue))

        def-atom (atom [])
        a1-atom  (atom [])
        a2-atom  (atom [])
        b-atom   (atom [])

        def-fn   #(swap! def-atom conj %)
        a1-fn    #(swap! a1-atom conj [:a1 %])
        a2-fn    #(swap! a2-atom conj [:a2 %])
        b-fn     #(swap! b-atom conj %)]
    (add-tap def-fn)
    (remove-tap b-fn)  ;; not an error
    (tap> "this is a test")

    ;; Wait for the tap thread to drain
    (.join tap-queue)

    (remove-tap def-fn)
    (tap> "this is not a test")

    (is (= ["this is a test"] @def-atom))
    (is (= [] @a1-atom))
    (is (= [] @a2-atom))
    (is (= [] @b-atom))

    (add-tap :a a1-fn)
    (add-tap :a a2-fn)
    (tap> :a "all a's get this value")
    (tap> :a "and this one!")
    (.join tap-queue)
    (remove-tap :a a2-fn)
    (tap> :a "but this is just for the top a")
    (.join tap-queue)

    (is (= ["this is a test"] @def-atom))
    (is (= [[:a1 "all a's get this value"]
            [:a1 "and this one!"]
            [:a1 "but this is just for the top a"]]
           @a1-atom))
    (is (= [[:a2 "all a's get this value"]
            [:a2 "and this one!"]]
           @a2-atom))
    (is (= [] @b-atom))))
