(ns tests.basilisp.core.test-printing-fns
  (:import os)
  (:require
   [basilisp.string :as str]
   [basilisp.test :refer [deftest are is testing]]))

(defrecord CustomPrint [value])
(defrecord DefaultDupPrint [value])
(defrecord BrokenPrint [])

(defmethod print-method CustomPrint
  [x writer]
  (.write writer "<")
  (.write writer (:value x))
  (.write writer ">"))

(defmethod print-method :tests.basilisp.core.test-printing-fns/wire
  [x writer]
  (.write writer (str "wire:" (:value x))))

(defmethod print-dup CustomPrint
  [x writer]
  (.write writer (str "dup:" (:value x))))

(defmethod print-method BrokenPrint
  [_ _]
  (throw (python/ValueError "unprintable")))

(deftest pr-test
  (testing "is dynamic"
    (is (= '(1) (binding [pr (fn [& more] more)] (pr 1)))))

  (testing "basic pr-str"
    (is (= "" (pr-str)))

    (are [expected args] (= expected (apply pr-str args))
      "\"\""            [""]
      ":kw"             [:kw]
      ":hi \"there\" 3" [:hi "there" 3]))

  (testing "*print-level* support"
    (let [v-str (pr-str (range 100))]
      (is (str/ends-with? v-str " 99)") v-str))

    (binding [*print-length* 4]
      (is (= "(0 1 2 3 ...)" (pr-str (range 5))))))

  (testing "with *print-namespace-maps*"
    (is (= "#py {:a/x 5}" (binding [*print-namespace-maps* false] (pr-str #py {:a/x 5}))))
    (is (= "#py #:a{:x 5}" (binding [*print-namespace-maps* true] (pr-str #py {:a/x 5}))))

    (are [res m b] (contains? res (binding [*print-namespace-maps* b] (pr-str m)))
      #{"{:a/x 5}"}                            {:a/x 5}        false
      #{"#:a{:x 5}"}                           {:a/x 5}        true
      #{"{:x 5}"}                              {:x 5}          true
      #{"{1 2}"}                               {1 2}           false
      #{"{1 2}"}                               {1 2}           true
      #{"{:a/y 6, :a/x 5}" "{:a/x 5, :a/y 6}"} {:a/x 5 :a/y 6} false
      #{"#:a{:y 6, :x 5}" "#:a{:x 5, :y 6}"}   {:a/x 5 :a/y 6} true
      #{"{6 6, :a/x 5}" "{:a/x 5, 6 6}"}       {:a/x 5 6 6}    false
      #{"{6 6, :a/x 5}" "{:a/x 5, 6 6}"}       {:a/x 5 6 6}    true
      #{"{:a/x 5, :b/y 6}" "{:b/y 6, :a/x 5}"} {:a/x 5 :b/y 6} true
      #{"#:a{y 6, x 5}" "#:a{x 5, y 6}"}       {'a/x 5 'a/y 6} true
      #{"#:a{y 6, :x 5}" "#:a{:x 5, y 6}"}     {:a/x 5 'a/y 6} true
      #{"{y 6, :a/x 5}" "{:a/x 5, y 6}"}       {:a/x 5 'y 6}   true)

    (are [res m pnm pm] (= res (binding [*print-namespace-maps* pnm
                                         *print-meta*           pm]
                                 (pr-str m)))
      "^{:m 1} {:a/x 5}"     ^{:m 1} {:a/x 5}   false true
      "^{:m 1} #:a{:x 5}"    ^{:m 1} {:a/x 5}   true  true
      "^#:l{:m 1} #:a{:x 5}" ^{:l/m 1} {:a/x 5} true  true)

    (are [res m pl] (= res (binding [*print-namespace-maps* true
                                     *print-meta*           true
                                     *print-level* pl]
                             (pr-str m)))
      "#"                                ^{:m 1} {:a/x 5}                0
      "^{:m 1} #:a{:x 5}"                ^{:m 1} {:a/x 5}                1
      "^{:m 1} #:a{:x #}"                ^{:m 1} {:a/x ^{:x 22} {:b 36}} 1
      "^{:m 1} #:a{:x ^{:x 22} {:b 36}}" ^{:m 1} {:a/x ^{:x 22} {:b 36}} 2)))

(deftest prn-str-test
  (is (= os/linesep (prn-str)))

  (are [expected args] (= expected (apply prn-str args))
    (str "\"\"" os/linesep)            [""]
    (str ":kw" os/linesep)             [:kw]
    (str ":hi \"there\" 3" os/linesep) [:hi "there" 3]))

(deftest print-str-test
  (is (= "" (print-str)))

  (are [expected args] (= expected (apply print-str args))
    ""            [""]
    ":kw"         [:kw]
    ":hi there 3" [:hi "there" 3]))

(deftest println-str-test
  (is (= os/linesep (println-str)))

  (are [expected args] (= expected (apply println-str args))
    os/linesep                    [""]
    (str ":kw" os/linesep)        [:kw]
    (str ":hi there 3" os/linesep) [:hi "there" 3]))

(deftest extensible-printing-test
  (testing "custom methods receive the active writer and apply to every public printer"
    (let [value (->CustomPrint "value")]
      (is (= "<value>" (pr-str value)))
      (is (= "<value>" (print-str value)))
      (is (= (str "<value>" os/linesep) (prn-str value)))
      (is (= (str "<value>" os/linesep) (println-str value)))))

  (testing "metadata :type dispatch takes precedence over the Python runtime type"
    (is (= "wire:value"
           (pr-str (with-meta (->CustomPrint "value")
                               {:type :tests.basilisp.core.test-printing-fns/wire}))))
    (is (= "[wire:value <other>]"
           (pr-str [(with-meta (->CustomPrint "value")
                               {:type :tests.basilisp.core.test-printing-fns/wire})
                    (->CustomPrint "other")]))))

  (testing "*print-dup* uses the corresponding custom print-dup method"
    (is (= "dup:value"
           (binding [*print-dup* true]
             (pr-str (->CustomPrint "value")))))
    (is (= "[dup:value]"
           (binding [*print-dup* true]
             (pr-str [(->CustomPrint "value")])))))

  (testing "print-dup does not fall back to print-method"
    (let [value (with-meta (->DefaultDupPrint "value")
                           {:type :tests.basilisp.core.test-printing-fns/wire})]
      (is (= (binding [*print-dup* true] (repr value))
             (binding [*print-dup* true] (pr-str value))))
      (is (= (str "[" (binding [*print-dup* true] (repr value)) "]")
             (binding [*print-dup* true] (pr-str [value]))))))

  (testing "a deterministic high-cardinality workload preserves order and separators"
    (let [values   (map (fn [n] (->CustomPrint (str n))) (range 1024))
          expected (str/join "|" (map (fn [n] (str "<" n ">")) (range 1024)))]
      (is (= expected
             (binding [*print-sep* "|"]
               (apply pr-str values))))))

  (testing "generated nested values dispatch custom printers without bypassing collection limits"
    (let [values   (vec (map (fn [n] [(->CustomPrint (str n)) n]) (range 256)))
          expected (str "["
                        (str/join " " (map (fn [n] (str "[<" n "> " n "]")) (range 256)))
                        "]")]
      (is (= expected (pr-str values)))
      (is (= "[[<0> 0] [<1> 1] ...]"
             (binding [*print-length* 2]
               (pr-str values))))))

  (testing "printer exceptions propagate without corrupting subsequent output"
    (is (thrown? python/ValueError (pr-str (->BrokenPrint))))
    (is (= "<still-usable>" (pr-str (->CustomPrint "still-usable"))))))

(deftest print-helper-test
  (testing "print-simple uses str without dispatching through print-method"
    (let [value  [(->CustomPrint "value") :key "text"]
          writer (io/StringIO)]
      (print-simple value writer)
      (is (= (str value) (.getvalue writer)))
      (is (not= (pr-str value) (.getvalue writer)))))

  (testing "print-simple emits metadata under Clojure's printing policy"
    (let [value (with-meta [1] {:tag 'kind})]
      (is (= "[1]"
             (let [writer (io/StringIO)]
               (print-simple value writer)
               (.getvalue writer))))
      (is (= "^kind ^kind [1]"
             (binding [*print-meta* true *print-readably* true]
               (let [writer (io/StringIO)]
                 (print-simple value writer)
                 (.getvalue writer)))))
      (is (= "^kind ^kind [1]"
             (binding [*print-dup* true]
               (let [writer (io/StringIO)]
                 (print-simple value writer)
                 (.getvalue writer)))))))

  (testing "print-ctor delegates arguments to its callback and labels Python types"
    (let [writer (io/StringIO)
          value  :value
          calls  (atom [])]
      (print-ctor value
                  (fn [object callback-writer]
                    (swap! calls conj object)
                    (.write callback-writer "ARGS"))
                  writer)
      (is (= [value] @calls))
      (is (= (str "#=(" (.-__module__ (python/type value)) "."
                  (.-__qualname__ (python/type value)) ". ARGS)")
             (.getvalue writer)))))

  (testing "callback failures remain visible to callers"
    (is (thrown? python/ValueError
                 (print-ctor :value
                             (fn [_ _] (throw (python/ValueError "broken callback")))
                             (io/StringIO))))))

(defn- bio-write
  "Helper fn to write the ``strings`` to the ByteIO buffer ``bio``
  and return the contents of the buffer."
  [bio & strings]
  (.write bio (python/bytes (apply str strings) "UTF-8"))
  (.getvalue bio))

(deftest flush-on-newline-test
  ;; :line-buffering false :newline ""
  ;;
  ;;   the above options instruct the TextIOWrapper to internally
  ;;   disable (1) flushing on newlines and (2) universal newlines
  ;;   mode.

  (testing "prn newline flushing"
    (let [bio      (io/BytesIO)
          expected (io/BytesIO)]
      (binding [*out* (io/TextIOWrapper bio ** :line-buffering false :newline "")
                *flush-on-newline* true]
        (prn)
        (is (= (bio-write expected os/linesep) (.getvalue bio)))
        (prn "ab")
        (is (= (bio-write expected "\"ab\"" os/linesep) (.getvalue bio)))
        (prn "ab" 1)
        (is (= (bio-write expected "\"ab\"" " " 1 os/linesep) (.getvalue bio))))))

  (testing "prn newline not flushing"
    (let [bio      (io/BytesIO)
          expected (io/BytesIO)]
      (binding [*out* (io/TextIOWrapper bio ** :line-buffering false :newline "")
                *flush-on-newline* false]
        (prn)
        (is (= #b "" (.getvalue bio)))
        (prn "ab")
        (is (= #b "" (.getvalue bio)))
        (prn "ab" 1)
        (is (= #b "" (.getvalue bio)))
        (.flush *out*)
        (is (= (bio-write expected os/linesep "\"ab\"" os/linesep "\"ab\"" " " 1 os/linesep)
               (.getvalue bio))))))

  (testing "println newline flushing"
    (let [bio      (io/BytesIO)
          expected (io/BytesIO)]
      (binding [*out* (io/TextIOWrapper bio ** :line-buffering false :newline "")
                *flush-on-newline* true]
        (println)
        (is (= (bio-write expected os/linesep) (.getvalue bio)))
        (println "ab")
        (is (= (bio-write expected "ab" os/linesep) (.getvalue bio)))
        (println "ab" 1)
        (is (= (bio-write expected "ab" " " 1 os/linesep) (.getvalue bio))))))

  (testing "println newline not flushing"
    (let [bio      (io/BytesIO)
          expected (io/BytesIO)]
      (binding [*out* (io/TextIOWrapper bio ** :line-buffering false :newline "")
                *flush-on-newline* false]
        (println)
        (is (= #b "" (.getvalue bio)))
        (println "ab")
        (is (= #b "" (.getvalue bio)))
        (println "ab" 1)
        (is (= #b "" (.getvalue bio)))
        (.flush *out*)
        (is (= (bio-write expected os/linesep "ab" os/linesep "ab" " " 1 os/linesep)
               (.getvalue bio)))))))
