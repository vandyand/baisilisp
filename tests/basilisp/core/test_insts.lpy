(ns tests.basilisp.core.test-insts
  (:import datetime)
  (:require
   [clojure.edn :as edn]
   [basilisp.test :refer [are deftest is]]))

(deftest inst?-test
  (is (inst? (datetime.datetime/now)))
  (is (not (inst? (datetime.date/today))))
  (is (not (inst? (datetime/time))))
  (is (not (inst? (python/object)))))

(deftest inst-ms-test
  (is (= 0 (inst-ms
            (datetime.datetime/fromtimestamp 0 datetime.timezone/utc))))
  (is (= 1723235558968
         (inst-ms #inst "2024-08-09T20:32:38.968-00:00")))
  (is (= -1
         (inst-ms #inst "1969-12-31T23:59:59.999Z"))))

(deftest reader-instant-timestamp-test
  (is (= 1262311321001
         (* 1000 (.timestamp (read-string "#inst \"2010-01-01T01:01:01.001-01:01\"")))))
  (are [millis source] (= [millis true]
                          (let [value (* 1000 (.timestamp (edn/read-string source)))]
                            [value (integer? value)]))
    1262311321001 "#inst \"2010-01-01T01:01:01.001-01:01\""
    1284056289009 "#inst \"2010-09-09T09:09:09.009-09:09\""
    1286742010010 "#inst \"2010-10-10T10:10:10.010-10:10\""
    1293926339999 "#inst \"2010-12-31T23:59:59.999-23:59\""
    1289585655666 "#inst \"2010-11-12T18:14:15.666Z\""
    1289585655666 "#inst \"2010-11-12T18:14:15.666-00:00\""
    1289585655666 "#inst \"2010-11-12T18:14:15.666+00:00\""
    1289585655666 "#inst \"2010-11-12T13:14:15.666-05:00\""
    1289585655666 "#inst \"2010-11-12T23:14:15.666+05:00\""
    1289567655000 "#inst \"2010-11-12T13:14:15Z\""
    482196050520  "#inst \"1985-04-12T23:20:50.52Z\""
    1770076800000 "#inst \"2026-02-03\""))
