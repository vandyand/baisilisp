(ns tests.basilisp.test-java-namespace-aliases
  (:import os
           pathlib
           sys)
  (:require
   [basilisp.io :as bio]
   [clojure.java.io :as io]
   [clojure.java.shell :as shell]
   [basilisp.test :refer [are deftest is]]))

(deftest clojure-java-io-import-path-test
  (is (= (pathlib/Path "parent" "child")
         (io/file "parent" "child")))
  (is (= (pathlib/Path "parent" "child")
         (bio/path "parent" "child")))
  (is (= (pathlib/Path "parent")
         (io/as-file "parent")))
  (is (= (pathlib/Path "parent" "child")
         (io/as-relative-path "parent/child")))
  (is (= "https" (.-scheme (io/as-url "https://example.com/path"))))
  (is (= "file" (.-scheme (io/as-url (pathlib/Path "parent")))))
  (is (nil? (io/as-url nil)))
  (is (nil? (io/resource "definitely-missing-resource")))
  (is (thrown? python/ValueError (io/as-url "relative/path")))
  (is (thrown? python/ValueError
               (io/as-relative-path (.resolve (pathlib/Path "absolute")))))
  (are [name] (thrown? python/TypeError (io/resource name))
    nil
    1
    :resource)
  (is (= #{"Coercions" "IOFactory" "as-file" "as-relative-path" "as-url" "copy" "default-streams-impl"
           "delete-file" "file" "input-stream" "make-input-stream" "make-output-stream" "make-parents"
           "make-reader" "make-writer" "output-stream" "reader" "resource" "writer"}
         (set (map name (keys (ns-publics 'basilisp.java.io))))))
  (is (every? #(contains? io/default-streams-impl %)
              [:make-reader :make-writer :make-input-stream :make-output-stream]))
  (is (not (contains? (set (map name (keys (ns-publics 'basilisp.java.io)))) "path")))
  (is (not (contains? (set (map name (keys (ns-publics 'basilisp.java.io)))) "exists?")))
  (is (not (contains? (set (map name (keys (ns-publics 'basilisp.java.io)))) "touch"))))

(deftest clojure-java-shell-import-path-test
  (is (= {:exit 0 :out (str "alias" os/linesep) :err ""}
         (shell/sh sys/executable "-c" "print('alias')")))
  (is (= #{"*sh-dir*" "*sh-env*" "sh" "with-sh-dir" "with-sh-env"}
         (set (map name (keys (ns-publics 'basilisp.java.shell))))))
  (is (= {:exit 0 :out "alias-env" :err ""}
         (shell/with-sh-env {"BASILISP_SHELL_ALIAS" "alias-env"}
           (shell/sh sys/executable
                     "-c"
                     "import os; print(os.environ['BASILISP_SHELL_ALIAS'], end='')"))))
  (is (= {:exit 0 :out "tests" :err ""}
         (shell/with-sh-dir "tests"
           (shell/sh sys/executable
                     "-c"
                     "import pathlib; print(pathlib.Path.cwd().name, end='')")))))
