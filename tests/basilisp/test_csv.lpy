(ns tests.basilisp.test-csv
  (:require
   [basilisp.csv :as csv]
   [clojure.data.csv :as data-csv]
   [basilisp.test :refer [deftest is are testing]])
  (:import io
           random))

(def test-csv-content
  "id,name,country
1,John,United Kingdom
2,Hanns,Germany
3,Jose,Spain")

(def test-csv-headers
  ["id" "name" "country"])

(def test-csv-rows
  '(["1" "John" "United Kingdom"]
    ["2" "Hanns" "Germany"]
    ["3" "Jose" "Spain"]))

(deftest read-csv-test
  (testing "string"
    (is (= '() (csv/read-csv "")))
    (is (= '() (csv/rows->maps (csv/read-csv "id,name"))))
    (is (= (concat [test-csv-headers] test-csv-rows)
           (csv/read-csv test-csv-content)))
    (is (= (map zipmap (repeat [:id :name :country]) test-csv-rows)
           (csv/rows->maps (csv/read-csv test-csv-content)))))

  (testing "file-like object"
    (with-open [f (io/StringIO)]
      (is (= '() (csv/read-csv f))))
    (with-open [f (io/StringIO "id,name")]
      (is (= '() (csv/rows->maps (csv/read-csv f)))))
    (with-open [f (io/StringIO test-csv-content)]
      (is (= (concat [test-csv-headers] test-csv-rows)
             (csv/read-csv f))))
    (with-open [f (io/StringIO test-csv-content)]
      (is (= (map zipmap (repeat [:id :name :country]) test-csv-rows)
             (csv/rows->maps (csv/read-csv f)))))))

(deftest write-csv-test
  (is (thrown? basilisp.lang.exception/ExceptionInfo
               (csv/write-csv (io/StringIO) [] :newline :wrong-nl)))

  (with-open [f (io/StringIO)]
    (csv/write-csv f [])
    (is (= "" (.getvalue f))))

  (with-open [f (io/StringIO)]
    (csv/write-csv f [test-csv-headers])
    (is (= "id,name,country\n" (.getvalue f))))

  (with-open [f (io/StringIO)]
    (csv/write-csv f (concat [test-csv-headers] test-csv-rows))
    (is (= (str test-csv-content "\n") (.getvalue f))))

  (testing "Clojure quote predicate and escaping contract"
    (let [out (io/StringIO)]
      (csv/write-csv out [["plain" "has,separator" "has\"quote" "has\nnewline"]])
      (is (= "plain,\"has,separator\",\"has\"\"quote\",\"has\nnewline\"\n"
             (.getvalue out))))
    (let [out (io/StringIO)]
      (data-csv/write-csv out [["a" "b"]] :separator ";" :quote "'" :quote? #(= "b" %)
                          :newline :cr+lf)
      (is (= "a;'b'\r\n" (.getvalue out))))
    (is (thrown? python/ValueError
                 (csv/write-csv (io/StringIO) [["x"]] :separator "::")))
    (is (thrown? python/ValueError
                 (csv/write-csv (io/StringIO) [["x"]] :quote "")))))

(deftest data-csv-import-and-seeded-round-trip-test
  (is (= #{"Read-CSV-From" "read-csv" "read-csv-from" "write-csv"}
         (set (map name (keys (ns-publics 'basilisp.data.csv))))))
  (is (= [["a" "b"] ["c" "d"]]
         (vec (data-csv/read-csv-from "a,b\nc,d" (int \,) (int \")))))
  (is (= [["a" "b"] ["c" "d"]]
         (vec (data-csv/read-csv-from (io/StringIO "a;b\nc;d") (int \;) (int \")))))
  (let [rng    (random/Random 0x435356)
        values (mapv (fn [_]
                       (str "v" (.randint rng 0 1000000) ",\"\n"))
                     (range 48))
        rows   (mapv vector values)
        out    (io/StringIO)]
    (data-csv/write-csv out rows)
    (is (= rows (vec (data-csv/read-csv (.getvalue out)))))))

(deftest character-delimiter-options-test
  (let [out (io/StringIO)]
    (csv/write-csv out [["left" "right"]] :separator \; :quote \|)
    (is (= "left;right\n" (.getvalue out)))
    (is (= [["left" "right"]]
           (vec (csv/read-csv (.getvalue out) :separator \; :quote \|))))))
