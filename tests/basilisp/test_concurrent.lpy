(ns tests.basilisp.test-concurrent
  (:import asyncio)
  (:require
   [basilisp.concurrent :as concurrent]
   [basilisp.test :refer [deftest is]]))

(defasync resolve-value []
  (await (asyncio/sleep 0))
  :resolved)

(defasync task-roundtrip []
  (let [task (concurrent/task (resolve-value))]
    (await task)))

(defasync queue-roundtrip []
  (let [queue (concurrent/queue)]
    (await (concurrent/queue-put! queue :queued))
    (await (concurrent/queue-get! queue))))

(defasync channel-roundtrip []
  (let [channel (concurrent/chan)
        putter  (asyncio/create-task (concurrent/put! channel :chan))]
    (let [value (await (concurrent/take! channel))]
      [value (await putter)])))

(defasync alts-roundtrip []
  (let [first  (concurrent/chan 1)
        second (concurrent/chan 1)]
    (await (concurrent/put! first :first))
    (await (concurrent/put! second :second))
    (let [[value selected] (await (concurrent/alts! [second first] :priority true))
          [fallback port]  (await (concurrent/alts! [(concurrent/chan)] :default :fallback))]
      [value (identical? selected second) fallback port])))

(defasync timeout-roundtrip []
  (let [timer (concurrent/timeout 1)]
    (await (concurrent/take! timer))))

(defasync pipeline-roundtrip []
  (let [source      (concurrent/chan 3)
        destination (concurrent/chan 3)]
    (await (concurrent/put! source 1))
    (await (concurrent/put! source 2))
    (await (concurrent/put! source 3))
    (concurrent/close! source)
    (let [runner (concurrent/pipeline! 2 source destination (map inc))]
      (await runner)
      [(await (concurrent/take! destination))
       (await (concurrent/take! destination))
       (await (concurrent/take! destination))
       (await (concurrent/take! destination))])))

(defasync alts-put-roundtrip []
  (let [first    (concurrent/chan)
        second   (concurrent/chan)
        selector (asyncio/create-task
                  (concurrent/alts! [[first :first] [second :second]]))]
    (await (asyncio/sleep 0))
    (let [value             (await (concurrent/take! second))
          [result selected] (await selector)]
      [value (= true result) (identical? selected second)])))

(deftest executor-test
  (let [executor (concurrent/thread-executor 1)]
    (try
      (is (= 3 @(concurrent/submit executor + 1 2)))
      (finally
        (concurrent/shutdown! executor)))))

(deftest agent-status-test
  (let [agent (agent 0)]
    (send agent + 1)
    (concurrent/wait agent)
    (is (= {:pending? false :error nil :error-mode "fail"}
           (concurrent/agent-status agent)))))

(deftest asyncio-adapter-test
  (let [awaitable (resolve-value)
        task-result (asyncio/run (task-roundtrip))
        queue-result (asyncio/run (queue-roundtrip))]
    (try
      (is (concurrent/awaitable? awaitable))
      (is (= :resolved task-result))
      (is (= :queued queue-result))
      (is (= [:chan true] (asyncio/run (channel-roundtrip))))
      (is (= [:second true :fallback :default]
             (asyncio/run (alts-roundtrip))))
      (is (nil? (asyncio/run (timeout-roundtrip))))
      (is (= [2 3 4 nil] (asyncio/run (pipeline-roundtrip))))
      (is (= [:second true true] (asyncio/run (alts-put-roundtrip))))
      (finally
        (.close awaitable)))))
